<?xml version="1.0"?>
<robot name="workpiece">
  <!-- Place your CAD-exported STL at meshes/workpiece.stl and enable in cnc_bed.yaml -->
  <link name="workpiece_link">
    <visual>
      <origin xyz="0 0 -0.005" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.01"/>
      </geometry>
      <material name="workpiece_blue">
        <color rgba="0.2 0.65 0.95 0.9"/>
      </material>
    </visual>
  </link>
</robot>
